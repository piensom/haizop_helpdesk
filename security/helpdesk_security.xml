<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="privilege_helpdesk" model="res.groups.privilege">
        <field name="name">Helpdesk</field>
        <field name="sequence">16</field>
    </record>

    <record id="group_helpdesk_user" model="res.groups">
        <field name="name">User: own tickets only</field>
        <field name="privilege_id" ref="privilege_helpdesk"/>
    </record>
    <record id="group_helpdesk_team_leader" model="res.groups">
        <field name="name">Team Leader</field>
        <field name="privilege_id" ref="privilege_helpdesk"/>
        <field name="implied_ids" eval="[(4, ref('group_helpdesk_user'))]"/>
    </record>
    <record id="group_helpdesk_manager" model="res.groups">
        <field name="name">Administrator</field>
        <field name="privilege_id" ref="privilege_helpdesk"/>
        <field name="implied_ids" eval="[(4, ref('group_helpdesk_team_leader'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <record id="helpdesk_ticket_rule_member" model="ir.rule">
        <field name="name">Helpdesk: members see their team tickets</field>
        <field name="model_id" ref="model_helpdesk_ticket"/>
        <field name="domain_force">['|', ('team_id.member_ids', 'in', [user.id]), ('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_helpdesk_user'))]"/>
    </record>
    <record id="helpdesk_ticket_rule_manager" model="ir.rule">
        <field name="name">Helpdesk: managers see all tickets</field>
        <field name="model_id" ref="model_helpdesk_ticket"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_helpdesk_manager'))]"/>
    </record>
    <record id="helpdesk_ticket_rule_portal" model="ir.rule">
        <field name="name">Helpdesk: portal sees own tickets</field>
        <field name="model_id" ref="model_helpdesk_ticket"/>
        <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
    </record>
</odoo>
