<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_helpdesk_sla_list" model="ir.ui.view">
        <field name="name">helpdesk.sla.list</field>
        <field name="model">helpdesk.sla</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="team_id"/>
                <field name="target_type"/>
                <field name="priority"/>
                <field name="time_hours"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="view_helpdesk_sla_form" model="ir.ui.view">
        <field name="name">helpdesk.sla.form</field>
        <field name="model">helpdesk.sla</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="team_id"/>
                            <field name="target_type"/>
                            <field name="priority"/>
                            <field name="ticket_type_id"/>
                        </group>
                        <group>
                            <field name="time_hours"/>
                            <field name="at_risk_ratio"/>
                            <field name="stage_id" invisible="target_type != 'resolution'"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="tag_ids" widget="many2many_tags"/>
                        <field name="partner_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_helpdesk_sla" model="ir.actions.act_window">
        <field name="name">SLA Policies</field>
        <field name="res_model">helpdesk.sla</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
