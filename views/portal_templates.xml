<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tile on /my portal home -->
    <template id="portal_my_home_helpdesk" name="Portal: Helpdesk entry" inherit_id="portal.portal_my_home" priority="50">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Tickets</t>
                <t t-set="url" t-value="'/my/tickets'"/>
                <t t-set="placeholder_count" t-value="'ticket_count'"/>
            </t>
        </xpath>
    </template>

    <!-- Shared HAIZOP shell for portal pages (hides default Odoo chrome) -->
    <template id="hz_portal_shell" name="HAIZOP portal shell">
        <t t-call="website.layout">
            <t t-set="no_header" t-value="True"/>
            <t t-set="no_footer" t-value="True"/>
            <t t-set="hide_header" t-value="True"/>
            <t t-set="hide_footer" t-value="True"/>
            <style>
                body &gt; header, body &gt; footer,
                body &gt; nav, body &gt; .o_main_navbar,
                #wrapwrap &gt; header, #wrapwrap &gt; footer,
                header#top, footer#footer, .o_header_standard,
                .o_footer, .o_footer_copyright { display: none !important; }
                body, #wrapwrap, main { margin: 0 !important; padding: 0 !important; background: #f8fafc !important; }
                #wrap { padding: 0 !important; }
            </style>
            <nav class="hz-portal-nav">
                <div class="hz-portal-nav-inner">
                    <a href="/" class="hz-portal-brand">◆ HAIZOP</a>
                    <div class="hz-portal-links">
                        <a href="/my/tickets">My tickets</a>
                        <a href="/helpdesk">New ticket</a>
                        <a href="/my" t-if="is_logged">My account</a>
                        <a href="/web/session/logout" t-if="is_logged">Log out</a>
                        <a href="/web/login" t-if="not is_logged">Log in</a>
                    </div>
                </div>
            </nav>
            <main class="hz-portal-main">
                <div class="hz-portal-container">
                    <t t-out="0"/>
                </div>
            </main>
            <footer class="hz-portal-footer">
                <div class="hz-portal-footer-inner">
                    <span>© 2026 HAIZOP GmbH, Leipzig</span>
                    <span>
                        <a href="/impressum">Impressum</a>
                        <a href="/datenschutz">Datenschutz</a>
                        <a href="mailto:info@haizop.com">Kontakt</a>
                    </span>
                </div>
            </footer>
        </t>
    </template>

    <!-- Ticket list -->
    <template id="portal_my_tickets" name="My Tickets">
        <t t-call="haizop_helpdesk.hz_portal_shell">
            <t t-set="is_logged" t-value="True"/>
            <div class="hz-portal-head">
                <h1>My tickets</h1>
                <a href="/helpdesk" class="hz-portal-btn hz-portal-btn-primary">+ New ticket</a>
            </div>
            <div t-if="not tickets" class="hz-portal-empty">
                <p>You have no tickets yet.</p>
                <a href="/helpdesk" class="hz-portal-btn hz-portal-btn-primary">Open your first ticket</a>
            </div>
            <table t-if="tickets" class="hz-portal-table">
                <thead>
                    <tr>
                        <th>Ticket</th>
                        <th>Subject</th>
                        <th>Status</th>
                        <th>SLA</th>
                        <th>Created</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="tickets" t-as="ticket">
                        <td>
                            <a t-attf-href="/my/ticket/#{ticket.id}" class="hz-portal-link">
                                <t t-out="ticket.number"/>
                            </a>
                        </td>
                        <td><t t-out="ticket.name"/></td>
                        <td>
                            <span class="hz-portal-badge"
                                  t-attf-data-state="#{'closed' if ticket.is_closed else 'open'}">
                                <t t-out="ticket.stage_id.name"/>
                            </span>
                        </td>
                        <td>
                            <span t-if="ticket.sla_status == 'breached'" class="hz-portal-badge hz-portal-badge-danger">Breached</span>
                            <span t-elif="ticket.sla_status == 'at_risk'" class="hz-portal-badge hz-portal-badge-warn">At risk</span>
                            <span t-elif="ticket.sla_status == 'reached'" class="hz-portal-badge hz-portal-badge-ok">On time</span>
                            <span t-else="" class="hz-portal-badge">—</span>
                        </td>
                        <td><t t-out="ticket.create_date.strftime('%Y-%m-%d %H:%M')"/></td>
                    </tr>
                </tbody>
            </table>
            <div t-if="pager" class="hz-portal-pager">
                <t t-call="portal.pager"/>
            </div>
        </t>
    </template>

    <!-- Ticket detail -->
    <template id="portal_ticket_page" name="Ticket">
        <t t-call="haizop_helpdesk.hz_portal_shell">
            <t t-set="is_logged" t-value="True"/>
            <div class="hz-portal-head">
                <div>
                    <a href="/my/tickets" class="hz-portal-back">← All tickets</a>
                    <h1>
                        <span class="hz-portal-number"><t t-out="ticket.number"/></span>
                        <t t-out="ticket.name"/>
                    </h1>
                </div>
                <div class="hz-portal-badges">
                    <span class="hz-portal-badge" t-attf-data-state="#{'closed' if ticket.is_closed else 'open'}">
                        <t t-out="ticket.stage_id.name"/>
                    </span>
                    <span t-if="ticket.sla_status == 'breached'" class="hz-portal-badge hz-portal-badge-danger">SLA breached</span>
                    <span t-if="ticket.sla_status == 'at_risk'" class="hz-portal-badge hz-portal-badge-warn">At risk</span>
                </div>
            </div>

            <div class="hz-portal-card">
                <h3>Description</h3>
                <div class="hz-portal-desc" t-out="ticket.description"/>
            </div>

            <div class="hz-portal-card">
                <h3>Conversation</h3>
                <t t-call="portal.message_thread">
                    <t t-set="object" t-value="ticket"/>
                </t>
            </div>

            <div class="hz-portal-card" t-if="not ticket.is_closed">
                <h3>Reply</h3>
                <form t-attf-action="/my/ticket/#{ticket.id}/reply" method="post" enctype="multipart/form-data">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <textarea name="body" class="hz-portal-input" rows="4" placeholder="Type your reply…" required="1"/>
                    <div class="hz-portal-file">
                        <label>Attach files (optional):
                            <input type="file" name="attachments" multiple="multiple"/>
                        </label>
                    </div>
                    <div class="hz-portal-actions">
                        <button type="submit" class="hz-portal-btn hz-portal-btn-primary">Send reply</button>
                    </div>
                </form>
            </div>

            <div class="hz-portal-card" t-if="not ticket.is_closed">
                <h3>Mark as solved</h3>
                <p class="hz-portal-muted">
                    If this is no longer an issue, close the ticket yourself. Pick a reason — helps us improve support.
                </p>
                <form t-attf-action="/my/ticket/#{ticket.id}/close" method="post">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <select name="reason" class="hz-portal-input">
                        <option value="solved">Solved</option>
                        <option value="duplicate">Duplicate of another ticket</option>
                        <option value="no_response">No response needed</option>
                        <option value="cannot_reproduce">Cannot reproduce</option>
                        <option value="other">Other</option>
                    </select>
                    <div class="hz-portal-actions">
                        <button type="submit" class="hz-portal-btn hz-portal-btn-outline">Close ticket</button>
                    </div>
                </form>
            </div>

            <div class="hz-portal-card" t-if="ticket.is_closed">
                <h3>Ticket closed</h3>
                <p class="hz-portal-muted">
                    Closed <t t-if="ticket.closed_date" t-out="ticket.closed_date.strftime('%Y-%m-%d %H:%M')"/>.
                    <t t-if="ticket.close_reason"> Reason: <t t-out="dict(ticket._fields['close_reason'].selection).get(ticket.close_reason)"/>.</t>
                </p>
                <form t-attf-action="/my/ticket/#{ticket.id}/reopen" method="post">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <button type="submit" class="hz-portal-btn hz-portal-btn-outline">Reopen ticket</button>
                </form>
            </div>
        </t>
    </template>

    <!-- Public ticket tracking page (no login, email verification) -->
    <template id="public_track_form" name="Track ticket — form">
        <t t-call="haizop_helpdesk.hz_portal_shell">
            <t t-set="is_logged" t-value="False"/>
            <div class="hz-portal-head">
                <h1>Track your ticket</h1>
            </div>
            <div class="hz-portal-card">
                <p class="hz-portal-muted">
                    Enter the ticket number you received and the email address you submitted the ticket with.
                    We'll show the current status.
                </p>
                <form action="/helpdesk/track" method="get">
                    <label>Ticket number
                        <input type="text" name="number" class="hz-portal-input" placeholder="HD00023" required="1"
                               t-att-value="number or ''"/>
                    </label>
                    <label>E-mail
                        <input type="email" name="email" class="hz-portal-input" placeholder="you@company.com" required="1"
                               t-att-value="email or ''"/>
                    </label>
                    <div class="hz-portal-actions">
                        <button type="submit" class="hz-portal-btn hz-portal-btn-primary">Check status</button>
                    </div>
                </form>
                <div t-if="error" class="hz-portal-alert hz-portal-alert-err">
                    <t t-out="error"/>
                </div>
            </div>
        </t>
    </template>

    <template id="public_track_result" name="Track ticket — result">
        <t t-call="haizop_helpdesk.hz_portal_shell">
            <t t-set="is_logged" t-value="False"/>
            <div class="hz-portal-head">
                <div>
                    <a href="/helpdesk/track" class="hz-portal-back">← Track another</a>
                    <h1>
                        <span class="hz-portal-number"><t t-out="ticket.number"/></span>
                        <t t-out="ticket.name"/>
                    </h1>
                </div>
                <span class="hz-portal-badge" t-attf-data-state="#{'closed' if ticket.is_closed else 'open'}">
                    <t t-out="ticket.stage_id.name"/>
                </span>
            </div>
            <div class="hz-portal-card">
                <dl class="hz-portal-dl">
                    <dt>Opened</dt><dd><t t-out="ticket.create_date.strftime('%Y-%m-%d %H:%M')"/></dd>
                    <dt>Last update</dt><dd><t t-out="(ticket.write_date or ticket.create_date).strftime('%Y-%m-%d %H:%M')"/></dd>
                    <dt>Priority</dt><dd><t t-out="dict(ticket._fields['priority'].selection).get(ticket.priority)"/></dd>
                    <dt t-if="ticket.sla_deadline">SLA deadline</dt>
                    <dd t-if="ticket.sla_deadline"><t t-out="ticket.sla_deadline.strftime('%Y-%m-%d %H:%M')"/></dd>
                </dl>
            </div>
            <div class="hz-portal-card">
                <p class="hz-portal-muted">
                    For a full conversation view and to reply, please <a href="/web/login">sign in to the customer portal</a>.
                    A login was sent to the e-mail on file when the ticket was created.
                </p>
            </div>
        </t>
    </template>

</odoo>
