<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="website_helpdesk_team" name="Helpdesk Team Form">
        <t t-call="haizop_helpdesk.hz_portal_shell">
            <t t-set="is_logged" t-value="False"/>
            <div class="hz-portal-head">
                <div>
                    <h1>How can we help?</h1>
                    <p class="hz-portal-muted">Submit a support request — we'll get back to you.</p>
                </div>
                <a href="/helpdesk/track" class="hz-portal-btn hz-portal-btn-outline">Track an existing ticket →</a>
            </div>

            <t t-if="submitted">
                <div class="hz-portal-alert hz-portal-alert-ok">
                    ✓ Thanks! Your ticket <strong t-out="submitted"/> was created. Check the e-mail for follow-up.
                </div>
            </t>

            <div class="hz-portal-card">
                <form t-attf-action="/helpdesk/#{team.id}/submit" method="post" enctype="multipart/form-data">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <label>Name *
                        <input type="text" name="name" class="hz-portal-input" required="1"/>
                    </label>
                    <label>E-mail *
                        <input type="email" name="email" class="hz-portal-input" required="1"/>
                    </label>
                    <label>Subject *
                        <input type="text" name="subject" class="hz-portal-input" required="1"/>
                    </label>
                    <label>Priority
                        <select name="priority" class="hz-portal-input">
                            <option value="1">Low</option>
                            <option value="2" selected="1">Normal</option>
                            <option value="3">High</option>
                            <option value="4">Urgent</option>
                        </select>
                    </label>
                    <label>Description *
                        <textarea name="description" rows="6" class="hz-portal-input" required="1"/>
                    </label>
                    <div class="hz-portal-file">
                        <label>Attach screenshots or logs (optional):
                            <input type="file" name="attachments" multiple="multiple"/>
                        </label>
                    </div>
                    <div class="hz-portal-actions">
                        <button type="submit" class="hz-portal-btn hz-portal-btn-primary">Submit ticket</button>
                    </div>
                    <p class="hz-portal-muted" style="margin-top: 12px;">
                        By submitting, you accept our <a href="/datenschutz">privacy policy</a>.
                    </p>
                </form>
            </div>
        </t>
    </template>
</odoo>
