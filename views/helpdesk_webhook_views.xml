<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_helpdesk_webhook_list" model="ir.ui.view">
        <field name="name">helpdesk.webhook.list</field>
        <field name="model">helpdesk.webhook</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="url"/>
                <field name="team_id"/>
                <field name="event_ids" widget="many2many_tags"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="view_helpdesk_webhook_form" model="ir.ui.view">
        <field name="name">helpdesk.webhook.form</field>
        <field name="model">helpdesk.webhook</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <field name="url" placeholder="https://hooks.slack.com/..."/>
                        <field name="secret" password="True"/>
                        <field name="team_id"/>
                        <field name="event_ids" widget="many2many_tags"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_helpdesk_webhook" model="ir.actions.act_window">
        <field name="name">Webhooks</field>
        <field name="res_model">helpdesk.webhook</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
